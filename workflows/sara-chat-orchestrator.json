    {
      "parameters": {
        "jsCode": "const binaryData = $input.item.binary;\nconst image = binaryData && binaryData.image ? binaryData.image : null;\nconst body = $input.item.json.body || {};\n\n// Obtener historial de mensajes devueltos por postgres\nconst rawHistory = $input.all().map(i => i.json);\n// PostgreSQL puede devolver arrays de records. Filtramos los validos y aseguramos orden\nconst chatHistory = rawHistory.filter(msg => msg.role).reverse();\n\nreturn [{\n  json: {\n    query: body.query || \"\",\n    base: body.base || \"privada\",\n    user_name: body.userName || body.user_name || \"Usuario\",\n    user_email: body.userEmail || body.user_email || \"no-email@satcomla.com\",\n    session_id: body.sessionId || body.session_id || \"unknown\",\n    image_base64: image ? image.data : null,\n    image_mime_type: image ? image.mimeType : null,\n    chat_history: chatHistory\n  }\n}];"
      },
      "id": "d1cef7a2-d0f3-4c80-8e33-da3d1acdfb98",
      "name": "Map Parameters",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        160
      ]
    },
    {
