        "method": "POST",
        "url": "https://satcomla.app.n8n.cloud/webhook/rag-query",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "10c27022-9932-4cec-b68b-ca2dbdb368d9",
      "name": "Call RAG Global",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        160,
        160
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ `INSERT INTO sara_chat_memory (session_id, role, content, user_name, user_email) VALUES ('${$('Map Parameters').item.json.session_id}', 'user', '${$('Map Parameters').item.json.query?.replace(/'/g, \"''\") || \"[Imagen]\"}', '${$('Map Parameters').item.json.user_name}', '${$('Map Parameters').item.json.user_email}'), ('${$('Map Parameters').item.json.session_id}', 'assistant', '${$json.response ? $json.response.replace(/'/g, \"''\") : \"Error en respuesta\"}', '${$('Map Parameters').item.json.user_name}', '${$('Map Parameters').item.json.user_email}');` }}",
        "options": {}
      },
